# Ollama local LLM (run: ollama serve && ollama pull llama3.2)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Scraper URL - use container name in Docker, localhost otherwise
SCRAPER_URL=http://localhost:8085

# Path to bulletpoints.json - ../data/bulletpoints.json locally, /data/bulletpoints.json in Docker
BULLETPOINTS_PATH=../data/bulletpoints.json
